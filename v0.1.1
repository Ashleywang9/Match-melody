let notes = []
let notes2 = []
let keySpacing = 90/9
let enable = []
let enable2 = []
let vals = ['.','.','.','.','.','.','.','.']
//the blue one
for(let i=0;i<8;i++){
    notes.push(gui.Fader({
    label:'',
    size: 0.6, border: 2, width:2,
    borderColor: [255,255,255],
    x:12 + i*keySpacing, y:86,
    textColor : [255,255,255],
    accentColor:[0,0,200], max:8,
    callback:x=> {
      if(part2) {
        console.log(x)
        if(x==0) {
          s2.seq[0].vals[i]='.'
          enable[i].set(0)
        }
        else {
          s2.seq[0].vals[i]=x
          enable[i].set(1)
        }
      }
      // if( x == 0 ) s2.seq[0].vals[i] = '.'
      // else s2.seq[0].vals[i] = x
    },
    showLabel: false, showValue: false,
    value: 0
  }))
  enable.push(gui.Toggle({
    label:'',
    size: 0.5, border: 2,
    borderColor: [255,255,255],
    x:12 + i*keySpacing, y:76,
    textColor : [255,255,255],
    accentColor:[0,0,200],
    callback:x=> {
      if(part2) x==0 ? s2.seq[0].vals[i] = '.' : s2.seq[0].vals[i] = notes[i].value
    },
    showLabel: false, showValue: false,
    value: 0
  }))
  notes[i].setLink('notes'+i)
  enable[i].setLink('enable'+i)
}
//the red onw
