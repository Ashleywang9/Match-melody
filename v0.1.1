let knobNames = ["octave", "cutoff", "Q", "attack", "decay", "volume"]
//
for(let i=0; i<6;i++){
  vAknobs.push(gui.Knob({
    label: knobNames[i],
    x: 12 + i*10, y: 10, 
    size:0.5,
    min:0, max: 1, curve: 2,
    callback: function(x){},
    textColor:[255,255,255],textSize:0.5,
    border: 0.5, accentColor:[255,0,0],
    showValue:false,
  }))
  vAknobs[i].setLink('vAknobs'+i)
}

vAknobs[0].max = 4
vAknobs[0].isInteger = true
vAknobs[0].callback = x=> {
  x = Math.floor(x)
  s.octave = x
}
